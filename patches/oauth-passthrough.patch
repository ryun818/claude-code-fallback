+def _notify_fallback_available():
+    """Send macOS notification when Anthropic returns 429/5xx, offering DeepSeek switch."""
+    try:
+        sticky = json.loads(STICKY_PATH.read_text())
+        if sticky.get("mode") != "claude":
+            return
+    except Exception:
+        pass
+
+    try:
+        cfg = load_config()
+        providers = list(cfg.fallback_models.keys())
+        actions = ",".join(providers) + ",様子見" if providers else "様子見"
+
+        result = subprocess.run(
+            [
+                NOTIFIER,
+                "-title", "🔄 Claude 制限検知",
+                "-subtitle", "429/5xx エラーが発生しました",
+                "-message", "フォールバック先を選択してください",
+                "-actions", actions,
+                "-closeLabel", "様子見",
+                "-timeout", "300",
+                "-sound", "Pop",
+                "-group", "claude-proxy-fallback",
+            ],
+            capture_output=True, text=True, timeout=310,
+        )
+        chosen = result.stdout.strip()
+        if chosen in providers:
+            STICKY_PATH.write_text(json.dumps({"mode": chosen}))
+            logger.info("User chose to switch to %s", chosen)
+            subprocess.run(
+                [NOTIFIER, "-title", f"🔄 {chosen} 切替完了", "-message", f"次のリクエストから {chosen} を使用します", "-sound", "Tink", "-group", "claude-proxy-fallback"],
+                timeout=10,
+            )
+    except Exception as e:
+        logger.error("Notification error: %s", e)
+
 
