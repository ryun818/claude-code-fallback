diff --git a/recovery-check.sh b/recovery-check.sh
new file mode 100755
index 0000000..b09bcad
--- /dev/null
+++ b/recovery-check.sh
@@ -0,0 +1,47 @@
+#!/bin/bash
+
+STICKY="/Users/ryun/.claude-code-proxy/sticky-config.json"
+NOTIFIER="/opt/homebrew/bin/terminal-notifier"
+CLAUDE="/Users/ryun/.local/bin/claude"
+
+# Claude モードなら何もしない
+MODE=$(/opt/homebrew/bin/jq -r '.mode // "claude"' "$STICKY" 2>/dev/null)
+[ "$MODE" = "claude" ] && exit 0
+
+# Pro Max アカウント経由で Claude に疎通テスト
+RESPONSE=$("$CLAUDE" -p "." --model haiku 2>&1)
+EXIT_CODE=$?
+
+echo "$(date): Health check exit_code=${EXIT_CODE}"
+
+if [ "$EXIT_CODE" -ne 0 ]; then
+  echo "$(date): API not yet recovered (exit ${EXIT_CODE})"
+  exit 0
+fi
+
+# 復旧確認 — アクションボタン通知
+RESULT=$("$NOTIFIER" \
+  -title "✅ Claude API復旧" \
+  -subtitle "現在は DeepSeek で動作中" \
+  -message "Claudeに戻しますか？" \
+  -actions "戻す,あと1時間" \
+  -closeLabel "あと1時間" \
+  -timeout 600 \
+  -sound Glass \
+  -group "claude-proxy-recovery")
+
+echo "$(date): User selected: ${RESULT}"
+
+if [ "$RESULT" = "戻す" ]; then
+  echo '{"mode": "claude"}' > "$STICKY"
+
+  "$NOTIFIER" \
+    -title "🎯 Claude復帰完了" \
+    -message "通常モードに戻りました" \
+    -sound Tink \
+    -group "claude-proxy-recovery"
+
+  echo "$(date): Switched back to Claude"
+fi
+
+exit 0
