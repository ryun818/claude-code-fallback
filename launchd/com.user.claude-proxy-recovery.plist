<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.__USERNAME__.claude-proxy-recovery</string>
	<key>ProgramArguments</key>
	<array>
		<string>__HOME__/.claude-code-proxy/recovery-check.sh</string>
	</array>
	<key>StartInterval</key>
	<integer>3600</integer>
	<key>RunAtLoad</key>
	<false/>
	<key>StandardOutPath</key>
	<string>/tmp/claude-proxy-recovery.log</string>
	<key>StandardErrorPath</key>
	<string>/tmp/claude-proxy-recovery.err</string>
</dict>
</plist>
